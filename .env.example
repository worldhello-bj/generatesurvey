# ── OpenAI / AI Provider ──────────────────────────────────────────────
# Comma-separated list of API keys (round-robin rotation)
OPENAI_API_KEYS=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
PARSE_MODEL=gpt-4o-mini

# Token pricing (USD per 1K tokens) — update to match your model
PROMPT_TOKEN_PRICE=0.00015
COMPLETION_TOKEN_PRICE=0.0006

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/surveydb

# ── Runtime cache / token ttl ────────────────────────────────────────
TASK_TTL=1800
DOWNLOAD_TOKEN_TTL=3600

# ── Admin ─────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
JWT_SECRET=change-me-to-a-long-random-string-32chars!!
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:80
